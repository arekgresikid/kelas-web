# Google OAuth Configuration
# Dapatkan di: https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Cloudflare Configuration (Modul 8)
# D1 biasanya diakses melalui API endpoint yang kamu buat di Cloudflare Workers
VITE_CF_WORKER_URL=https://auth-api.your-subdomain.workers.dev

# App Configuration
VITE_APP_TITLE=KelasWeb Indonesia
VITE_APP_ENV=development
